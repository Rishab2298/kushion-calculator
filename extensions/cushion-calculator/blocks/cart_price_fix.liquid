{% comment %}
  Cart Price Fix - App Embed Block
  Monitors cart items with custom pricing and ensures correct prices are displayed.
  Injects a "Customize" button on cushion cart items to re-open the calculator pre-filled.
{% endcomment %}

<script src="{{ 'cart-price-fix.js' | asset_url }}" defer></script>

<style>
  .cushion-price-wrapper {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .cushion-price-wrapper.cushion-loading .cushion-price-value {
    color: #666;
  }

  .cushion-spinner {
    display: inline-block;
    width: 12px;
    height: 12px;
    border: 2px solid #e0e0e0;
    border-top-color: #333;
    border-radius: 50%;
    animation: cushion-spin 0.8s linear infinite;
  }

  @keyframes cushion-spin {
    to { transform: rotate(360deg); }
  }

  .cushion-customize-btn {
    display: inline-block;
    margin-top: 6px;
    padding: 4px 10px;
    font-size: 0.78rem;
    color: #555;
    border: 1px solid #ccc;
    border-radius: 4px;
    text-decoration: none;
    background: #fff;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  .cushion-customize-btn:hover {
    border-color: #333;
    color: #111;
  }
</style>

{% schema %}
{
  "name": "Cart Price Fix",
  "target": "body",
  "settings": []
}
{% endschema %}
